# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
override.tf
override.tf.json

# OpenBao / Vault secrets & keys — NEVER commit these
*.unseal-keys*
*.recovery-keys*
*-init.json
root-token*
*.snap
*.snapshot

# TLS material
*.pem
*.key
*.crt
*.csr
!**/ca-bundle.example.crt

# Local env
.env
.env.*
!.env.example

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Claude Code local settings (user-specific)
.claude/settings.local.json

# Local secrets dir written by scripts/bootstrap-init.sh
.secrets/
